PORT=4000
MONGODB_URI=mongodb://localhost:27017/i-planner
CORS_ORIGIN=*

# Firebase Admin (for verifying ID tokens from the app) — pick ONE approach:
# 1) Paste the full service account JSON as a single line here, or
FIREBASE_SERVICE_ACCOUNT_JSON=
# 2) leave the above blank and set GOOGLE_APPLICATION_CREDENTIALS to a key file path instead,
#    or rely on it being auto-detected in a deployed GCP/Firebase environment.
FIREBASE_PROJECT_ID=

# Google Calendar OAuth (backend-relay flow — see src/routes/googleOAuth.routes.ts).
# Create a "Web application" type OAuth Client ID in Google Cloud Console with
# authorized redirect URI: <BACKEND_PUBLIC_URL>/api/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Any long random string, used to HMAC-sign the short-lived `state` param.
GOOGLE_OAUTH_STATE_SECRET=
# The backend's own publicly-reachable base URL — Google redirects here after consent.
BACKEND_PUBLIC_URL=

# OpenAI API key (platform.openai.com → API keys) — powers AI goal milestone
# generation (src/services/goalMilestones.ts) and, later, the AI Coach and
# onboarding generation.
OPENAI_API_KEY=
